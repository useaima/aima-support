{
  "version": 2,
  "outputDirectory": ".",
  "public": true,
  "routes": [
    {
      "src": "/.*",
      "methods": ["GET", "HEAD"],
      "dest": "/index.html",
      "headers": {
        "Cache-Control": "public, max-age=3600, s-maxage=3600"
      }
    },
    {
      "src": "/index.html",
      "headers": {
        "Cache-Control": "public, max-age=0, s-maxage=3600, must-revalidate"
      }
    }
  ]
}